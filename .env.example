NODE_ENV=development
DATABASE_URL=postgresql://postgres:postgresql@127.0.0.1:5432/postgres
PORT=5000

SUPER_ADMIN_PASSWORD=123456
BCRYPT_SALT_ROUNDS=12

JWT_ACCESS_SECRET="secret"
JWT_REFRESH_SECRET="secret"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_EXPIRES_IN="7d"

# Firebase Configuration
# Note: FIREBASE_PRIVATE_KEY should have literal \n characters (not actual newlines)
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvgIBA....\n-----END PRIVATE KEY-----\n"
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_ID=your-firebase-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-...

# Email Configuration
EMAIL=your-email@gmail.com
APP_PASS=your-app-password

# S3/DigitalOcean Spaces Configuration
DO_SPACE_ENDPOINT=https://your-space.digitaloceanspaces.com
DO_SPACE_ACCESS_KEY=your-access-key
DO_SPACE_SECRET_KEY=your-secret-key
DO_SPACE_BUCKET=your-bucket-name

# AWS Configuration
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# Stripe Configuration
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_PLATFORM_ACCOUNT_ID=your-platform-account-id

# Apple IAP Configuration
APPLE_PRIVATE_KEY_PATH=AuthKey_ZCH3L987YV.p8
APPLE_BUNDLE_ID=com.example.app
APPLE_ISSUER_ID=your-issuer-id
APPLE_TEAM_ID=your-team-id
APPLE_KEY_ID=your-key-id
APPLE_SHARED_SECRET_KEY=your-shared-secret

# Google Play IAP Configuration
GOOGLE_PACKAGE_NAME=com.example.app
GOOGLE_IAP_CREDENTIALS={"type":"service_account","project_id":"..."}

# URLs
BACKEND_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:3000

TIMEZONE=UTC