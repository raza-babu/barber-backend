model SaloonOwner {
  id                 String   @id @default(auto()) @map("_id") @db.ObjectId
  userId             String   @unique @db.ObjectId
  shopName           String
  registrationNumber String   @unique
  shopAddress        String
  shopBio            String?
  latitude           Float?
  longitude          Float?
  shopLogo           String?
  shopImages         String[]
  shopVideo          String[]
  qrCode             String?
  isQueueEnabled     Boolean  @default(false) // If queue system is enabled
  isVerified         Boolean  @default(false)
  followerCount      Int      @default(0)
  followingCount     Int      @default(0)
  ratingCount        Int      @default(0)
  avgRating          Float?   @default(0)
  jobPostCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  // Relationships
  user                       User                @relation(fields: [userId], references: [id])
  Booking                    Booking[]
  Barber                     Barber[]
  SaloonReport               SaloonReport[]
  SaloonSchedule             SaloonSchedule[]
  SaloonHoliday              SaloonHoliday[]
  QrCode                     QrCode[]
  CustomerVisit              CustomerVisit[]
  CustomerLoyalty            CustomerLoyalty[]
  // Service           Service[]
  NonRegisteredUserQueueSlot NonRegisteredUser[]
  FavoriteShop               FavoriteShop[]
  jobPosts                   JobPost[]
  JobApplication             JobApplication[]
  Support                    Support[]
  Review                     Review[]
  LoyaltyPointLog            LoyaltyPointLog[]

  @@map("saloon_owners")
}
